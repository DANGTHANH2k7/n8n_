    {
      "parameters": {
        "jsCode": "const visitId = $item(0).$node['Webhook QA'].json.body.visitId;\nconst patientName = $item(0).$node['Webhook QA'].json.body.patientName || '';\nconst question = $item(0).$node['Webhook QA'].json.body.question || '';\nconst rows = items.map(i => i.json);\n\nlet found = rows.find(r => r.visit_id === visitId);\nif (!found && patientName) {\n  const candidates = rows.filter(r => r.patient_name === patientName);\n  if (candidates.length) {\n    found = candidates[candidates.length - 1];\n  }\n}\n\nif (!found) {\n  return [{ json: { error: 'Visit not found', visitId, patientName, question } }];\n}\n\nreturn [{ json: {\n  visitId: found.visit_id,\n  patientName: found.patient_name,\n  diagnosis: found.diagnosis,\n  diagnosisSimplified: found.diagnosis_simplified,\n  doctorAdvice: found.doctor_advice || '',\n  medicationsJson: found.medications_json || '[]',\n  instructionsJson: found.instructions_json || '[]',\n  question\n} }];"
      },
      "id": "89d07f84-e9d6-4574-b4ec-7d63f5a24937",
