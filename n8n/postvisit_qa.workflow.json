    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={{$env.GEMINI_API_KEY}}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"Bạn là trợ lý AI hậu khám, nói tiếng Việt dễ hiểu và an toàn.\\n- Chỉ trả lời dựa trên ngữ cảnh hồ sơ bên dưới.\\n- Ưu tiên bám sát lời dặn bác sĩ.\\n- Không đưa chẩn đoán mới.\\n- Nếu có dấu hiệu nguy hiểm, khuyên bệnh nhân liên hệ bác sĩ/cấp cứu.\\n\\nNgữ cảnh bệnh nhân:\\n- Mã buổi khám: {{$json.visitId}}\\n- Tên: {{$json.patientName}}\\n- Chẩn đoán: {{$json.diagnosis}}\\n- Giải thích đơn giản: {{$json.diagnosisSimplified}}\\n- Lời dặn bác sĩ: {{$json.doctorAdvice}}\\n- Thuốc (JSON): {{$json.medicationsJson}}\\n- Hướng dẫn (JSON): {{$json.instructionsJson}}\\n\\nCâu hỏi bệnh nhân:\\n{{$json.question}}\"\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"temperature\": 0.3\n  }\n}",
        "options": {}
      },
      "id": "0f7bb7cc-88cb-4a31-9c11-818e80a25196",
      "name": "Gemini Answer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1220,
        420
      ]
    },
    {
      "parameters": {
        "jsCode": "const answer = $json.candidates?.[0]?.content?.parts?.[0]?.text || 'Xin lỗi, tôi chưa thể trả lời lúc này.';\nconst source = $item(0).$node['Find Visit Context'].json;\nconst now = new Date().toISOString();\n\nreturn [{\n  json: {\n    qa_id: `QA_${Date.now()}`,\n    visit_id: source.visitId,\n    patient_name: source.patientName,\n    question: source.question,\n    answer,\n    created_at: now\n  }\n}];"
      },
