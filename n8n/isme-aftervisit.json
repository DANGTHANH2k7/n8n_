      "parameters": {
        "jsCode": "const now = new Date();\nconst hh = String(now.getHours()).padStart(2, '0');\nconst rows = items.map(i => i.json);\n\nconst due = rows.filter(r => {\n  if ((r.completed || '').toUpperCase() === 'TRUE') return false;\n  const slot = (r.time_slot || '').trim();\n  const hour = slot.split(':')[0]?.padStart(2, '0');\n  return hour === hh;\n});\n\nif (!due.length) return [{ json: { none: true, message: 'No reminders due this hour', at: now.toISOString() } }];\n\nreturn due.map(r => ({\n  json: {\n    reminder_id: r.reminder_id,\n    patient_id: r.patient_id,\n    visit_date: r.visit_date,\n    patient_name: r.patient_name,\n    medication_name: r.medication_name,\n    dosage: r.dosage,\n    time_slot: r.time_slot,\n    message: `Nhac nho: ${r.patient_name} den gio dung ${r.medication_name} ${r.dosage} (${r.time_slot})`,\n    sent_at: now.toISOString()\n  }\n}));"
      },
