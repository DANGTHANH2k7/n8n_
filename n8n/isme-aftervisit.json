    {
      "parameters": {
        "jsCode": "// Lấy data gốc từ bước Normalize (tránh bị Google Sheets làm mất)\nconst source = $items('Normalize Parsed Result')[0].json;\nconst qs = JSON.parse(source.unasked_questions_json || '[]');\nconst out = [];\n\nfor (const q of qs) {\n  const text = String(q || '').trim();\n  if (!text) continue;\n  \n  out.push({\n    json: {\n      question_id: `PQ_${source.patient_id}_${source.visit_date}_${Date.now()}_${Math.floor(Math.random()*10000)}`,\n      patient_id: source.patient_id,\n      visit_date: source.visit_date,\n      patient_name: source.patient_name,\n      patient_question: text,\n      doctor_answer: '',\n      status: 'pending',\n      created_at: source.parsed_at,\n      answered_at: ''\n    }\n  });\n}\nreturn out;"
      },
