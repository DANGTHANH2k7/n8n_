      "id": "74e6b558-8b2e-4b78-bb0e-b629e55f57a9",
      "name": "Append Structured Visit",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [
        -64,
        304
      ],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "HLVLHyVgg6Jxdf2f",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Lấy data gốc từ bước Normalize (tránh bị Google Sheets làm mất)\nconst source = $items('Normalize Parsed Result')[0].json;\nconst meds = JSON.parse(source.medications_json || '[]');\nconst out = [];\n\nfor (const med of meds) {\n  const timingText = String(med.timing || '').trim();\n  if (!timingText || timingText.toLowerCase() === 'chua duoc chi dinh') continue;\n  \n  let slots = [];\n  // Tìm mốc giờ chuẩn xác (vd: \"08:00\", \"20:00\")\n  const timeRegex = /\\d{1,2}:\\d{2}/g;\n  const timeMatches = timingText.match(timeRegex);\n  \n  if (timeMatches && timeMatches.length > 0) {\n    // Nếu tìm thấy giờ chuẩn (HH:mm) thì dùng luôn\n    slots = timeMatches;\n  } else {\n    // Nếu không có giờ chuẩn, cắt chuỗi theo dấu phẩy hoặc chữ \"và\", \"va\"\n    slots = timingText\n      .split(/(?:[+,;\\/]| và | va | and )/i)\n      .map(s => s.replace(/^(lúc|luc)\\s+/i, '').trim()) // Xóa chữ \"lúc\" ở đầu\n      .filter(Boolean);\n  }\n\n  for (const slot of slots) {\n    out.push({\n      json: {\n        reminder_id: `R_${source.patient_id}_${source.visit_date}_${Date.now()}_${Math.floor(Math.random()*10000)}`,\n        patient_id: source.patient_id,\n        visit_date: source.visit_date,\n        patient_name: source.patient_name,\n        medication_name: med.name || '',\n        dosage: med.dosage || '',\n        time_slot: slot,\n        frequency: med.frequency || '',\n        completed: 'FALSE',\n        last_reminder: source.parsed_at\n      }\n    });\n  }\n}\nreturn out;"
      },
