      "parameters": {
        "jsCode": "const patientId = $item(0).$node['Webhook QA'].json.body.patientId;\nconst question = $item(0).$node['Webhook QA'].json.body.question || '';\nconst rows = items.map(i => i.json);\n\nconst patientVisits = rows.filter(r => String(r.patient_id || r.ma_benh_nhan || '') === String(patientId));\n\nif (!patientVisits.length) {\n  return [{ json: { error: 'Patient not found', patientId, question } }];\n}\n\n// Sort visits by date conceptually, assuming they are appended chronologically\nconst latestVisit = patientVisits[patientVisits.length - 1];\n\nconst context = patientVisits.map(v => `Ngày khám: ${v.visit_date}\\nChẩn đoán: ${v.diagnosis || v.chan_doan}\\nLời dặn: ${v.doctor_advice || v.loi_dan || ''}\\nThuốc: ${v.medications_json || '[]'}\\nHướng dẫn: ${v.instructions_json || '[]'}`).join('\\n\\n---\\n\\n');\n\nreturn [{ json: {\n  patientId: latestVisit.patient_id,\n  patientName: latestVisit.patient_name,\n  latestVisitDate: latestVisit.visit_date,\n  context,\n  question\n} }];"
      },
