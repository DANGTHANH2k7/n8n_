    {
      "parameters": {
        "jsCode": "const qs = JSON.parse($json.unasked_questions_json || '[]');\nconst out = [];\nfor (const q of qs) {\n  const text = String(q || '').trim();\n  if (!text) continue;\n  out.push({\n    json: {\n      question_id: `PQ_${$json.visit_id}_${Date.now()}_${Math.floor(Math.random()*10000)}`,\n      visit_id: $json.visit_id,\n      patient_name: $json.patient_name,\n      patient_question: text,\n      doctor_answer: '',\n      status: 'pending',\n      created_at: $json.parsed_at,\n      answered_at: ''\n    }\n  });\n}\nreturn out;"
      },
