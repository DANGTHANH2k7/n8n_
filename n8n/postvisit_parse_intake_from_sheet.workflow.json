            "medications_json": "={{$json.medications_json}}",
            "instructions_json": "={{$json.instructions_json}}",
            "red_flags_json": "={{$json.red_flags_json}}",
            "follow_up_json": "={{$json.follow_up_json}}",
            "recording_text": "={{$json.raw_note}}",
            "doctor_advice": "={{$json.doctor_advice}}",
            "created_at": "={{$json.parsed_at}}"
          }
        },
