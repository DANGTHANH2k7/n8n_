    {
      "parameters": {
        "jsCode": "const meds = JSON.parse($json.medications_json || '[]');\nconst out = [];\nfor (const med of meds) {\n  const timingText = String(med.timing || '').trim();\n  if (!timingText || timingText.toLowerCase() === 'chua duoc chi dinh') continue;\n  const slots = timingText.split(/[+,;\\/]/).map(s => s.trim()).filter(Boolean);\n  for (const slot of slots) {\n    out.push({\n      json: {\n        reminder_id: `R_${$json.visit_id}_${Date.now()}_${Math.floor(Math.random()*10000)}`,\n        visit_id: $json.visit_id,\n        patient_name: $json.patient_name,\n        medication_name: med.name || '',\n        dosage: med.dosage || '',\n        time_slot: slot,\n        frequency: med.frequency || '',\n        completed: 'FALSE',\n        last_reminder: $json.parsed_at\n      }\n    });\n  }\n}\nreturn out;"
      },
