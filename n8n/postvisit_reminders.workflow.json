          "name": "Google Sheets OAuth2"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Optional: call webhook/Slack/Email here.\n// For MVP demo, this node just passes data through for logging.\nreturn items;"
      },
      "id": "51f99152-20d6-4d7c-a8e8-884e5f44bf7f",
      "name": "Dispatch Notification Stub",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1220,
